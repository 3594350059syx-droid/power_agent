# Python 编译缓存、打包产物
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Python 虚拟环境
.venv/
venv/

# Node 前端补充（你的frontend必须加，防止上传node_modules）
node_modules/
dist/

# IDE 配置文件夹
.idea/
.vscode/

# 环境变量密钥文件
.env

# 系统隐藏垃圾文件
.DS_Store
Thumbs.db

# 模型权重文件（体积大，不上传仓库）
models/checkpoints/*.pth
models/checkpoints/*.pt

# 本地数据库文件
data/database/*.db

